# Project-specific: data and secrets
# data/: exclude all contents except the tracked markers and the snapshot
# manifest. The pattern uses path-globs (not the directory shorthand) so
# git can traverse the directory and re-include specific files. Reference:
# https://git-scm.com/docs/gitignore#_examples
data/*
!data/.gitkeep
!data/snapshots
data/snapshots/*
!data/snapshots/manifest.toml
cache/
artifacts/
runs/
notebooks/scratch/
*.parquet
*.feather
*.h5
*.hdf5
*.duckdb
*.sqlite
*.csv
!docs/**/*.csv
!tests/**/*.csv

# Secrets (defense in depth; .env covered above)
secrets/
*.pem
*.key
*.crt
credentials.json
service-account*.json

# Vendor docs scraped to text (Nasdaq Data Link, SSGA, etc.) stay local
# to avoid pasting third-party content into the repo. The summarized
# reference at docs/vendor/ is the canonical project artifact.
Nasdaq API Docs.txt
*.vendor-scrape.txt

# Local agent / scratch
.claude/local/
.claude/settings.local.json
scratch/
scratch_*.py
_scratch_*.py
